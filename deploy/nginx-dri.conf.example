# Скопировать в /etc/nginx/sites-available/dri.maks1mio.su
# и сделать symlink: ln -s /etc/nginx/sites-available/dri.maks1mio.su /etc/nginx/sites-enabled/
# Должен совпадать PORT с PM2 (по умолчанию 3004 в ecosystem.config.cjs)
#
# certbot --nginx -d dri.maks1mio.su

map $http_upgrade $connection_upgrade {
  default upgrade;
  ''      close;
}

server {
  listen 80;
  listen [::]:80;
  server_name dri.maks1mio.su;

  # После certbot сюда добавятся редирект на HTTPS и ssl_certificate

  location / {
    proxy_pass http://127.0.0.1:3004;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_read_timeout 86400;
    client_max_body_size 50m;
  }
}
