# Для локальной разработки по http://localhost оставьте development — иначе cookie OAuth с флагом Secure не сохранятся.
NODE_ENV=production

# Публичный URL сайта (для ссылок и сборки URL картинок, например https://dri.maks1mio.su)
APP_URL=

# Необязательно: полный базовый URL картинок. Если пусто — будет APP_URL + MEDIA_URL_PATH
PUBLIC_IMAGE_BASE=
CDN_BASE=

# URL-префикс раздачи файлов с диска (совпадает с Express static в modules/nuxt-api/handler.js)
MEDIA_URL_PATH=/media

# Каталог на сервере, куда пишутся PNG (абсолютный путь предпочтительно на VPS)
# UPLOAD_DIR=/var/www/discord-reactive-images/uploads/images
UPLOAD_DIR=

PROMO_VIDEO_URL=

# Опционально: общий код для входа на сайт (если пусто — ворота отключены).
# Подпись cookie: ACCESS_COOKIE_SECRET или JWT_KEY (base64).
SITE_ACCESS_CODE=
ACCESS_COOKIE_SECRET=

# ID приложения (OAuth + локальный RPC к Discord Desktop). В Portal: OAuth2 → Redirects — callback; для браузерного RPC нужен origin вкладки (часто http://localhost:3000) в настройках приложения / тестеры до публикации.
DISCORD_ID=
DISCORD_SECRET=

NACL_KEY=
JWT_KEY=

DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=
DB_TABLE_PREFIX=
